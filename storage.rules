rules_version = '2';

// Cloud Storage for Firebase.
//
// company_logos/{companyId}/logo — the only path in use. Company owners
// upload to a fixed filename (no extension; contentType comes from upload
// metadata) so a re-upload overwrites the old logo instead of accumulating
// orphaned files. Everything else stays denied.
service firebase.storage {
  match /b/{bucket}/o {
    match /company_logos/{companyId}/{fileName} {
      allow read: if true;                                  // logos shown publicly
      allow write: if request.auth != null                  // owner-only upload
        && request.auth.uid == companyId
        && request.resource.size < 2 * 1024 * 1024          // 2 MB cap
        && request.resource.contentType.matches('image/(jpeg|png)');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
