# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Flutter/Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/doc/api/
app.*.symbols
app.*.map.json

# IDE
.idea/
*.iml
*.ipr
*.iws

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
