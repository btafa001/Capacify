rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // isAdmin is a manually-set flag on the user's own doc (see
    // users/{uid} below) — never settable via the client SDK, only from
    // the Firebase Console, so this can't be self-granted.
    //
    // exists() + .get('isAdmin', false), NOT a bare .data.isAdmin: auth_service.dart
    // never writes an isAdmin key when it creates a user doc, so on EVERY normal
    // (non-admin) account that field is simply absent — and a bare .data.isAdmin on
    // a doc missing the key errors the whole expression rather than evaluating
    // false. Because this helper is OR'd into the middle of other rules, that error
    // aborted the entire chain and denied the request before the branch that would
    // legitimately have allowed it was ever reached (contact_requests read below is
    // exactly that shape — it was why a normal account could never open Erhaltene
    // Anfragen while an admin account, whose doc does carry the key, was fine).
    // Same failure mode, and same .get(key, default) fix, as the users/{uid} update
    // rule further down already documents for 'plan'.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // True if `reqId` names a GRANTED contact_request that actually connects
    // companyA and companyB (in either direction: one is the requester, the
    // other is the post's owner via the locked capacityOwners sidecar). Used
    // to gate a rating on a real collaboration rather than any two accounts —
    // previously submitRating() had no check anywhere that rater and rated
    // had ever interacted, so any account could rate any other. Mirrors the
    // exists()-before-get() chaining used throughout this file (e.g. the
    // contact_requests/chats rules below) so a bogus/missing reqId fails
    // closed instead of erroring the whole rule; repeated identical get()
    // calls are cached within one rule evaluation, so this costs no more
    // reads than writing it with intermediate variables would.
    function isGrantedConnectionBetween(reqId, companyA, companyB) {
      return exists(/databases/$(database)/documents/contact_requests/$(reqId))
        && get(/databases/$(database)/documents/contact_requests/$(reqId)).data.status == 'granted'
        && exists(/databases/$(database)/documents/capacityOwners/$(get(/databases/$(database)/documents/contact_requests/$(reqId)).data.postId))
        && (
             ( get(/databases/$(database)/documents/contact_requests/$(reqId)).data.requesterCompanyId == companyA
               && get(/databases/$(database)/documents/capacityOwners/$(get(/databases/$(database)/documents/contact_requests/$(reqId)).data.postId)).data.posterCompanyId == companyB )
          || ( get(/databases/$(database)/documents/contact_requests/$(reqId)).data.requesterCompanyId == companyB
               && get(/databases/$(database)/documents/capacityOwners/$(get(/databases/$(database)/documents/contact_requests/$(reqId)).data.postId)).data.posterCompanyId == companyA )
        );
    }

    // True if either company has blocked the other (userBlocks/{blockerId}_
    // {blockedId} — see that collection below). Checked both directions since
    // a block should stop contact regardless of who initiates: the blocker
    // shouldn't be re-contacted by the company they blocked, and shouldn't be
    // able to accidentally re-open contact with them either. Used by
    // contact_requests' create rule — the only place NEW contact between two
    // companies originates (anonymous-mode posts don't even reveal the
    // poster's identity to the requester until here, via the capacityOwners
    // get() below, so this is also the earliest point a block CAN be
    // enforced for that mode, not just a convenience check).
    function isBlockedEitherWay(companyA, companyB) {
      return exists(/databases/$(database)/documents/userBlocks/$(companyA + '_' + companyB))
          || exists(/databases/$(database)/documents/userBlocks/$(companyB + '_' + companyA));
    }

    // The caller's OWN company doc — the server-pinned source of truth for
    // every trust signal a post snapshots (verificationStatus/ratingSum/
    // ratingCount are all admin-only on companies/{companyId}, see that rule).
    // exists() is split out so a caller with no company doc yet fails the
    // branch instead of erroring the whole rule on a get() of a missing doc.
    function callerCompanyExists() {
      return exists(/databases/$(database)/documents/companies/$(request.auth.uid));
    }

    function callerCompany() {
      return get(/databases/$(database)/documents/companies/$(request.auth.uid)).data;
    }

    // ─── Poster identity + trust snapshots on a public post (owner update) ───
    // H1 fix. The capacities CREATE rule carefully cross-checks identity
    // against the caller's own company doc — but the owner-UPDATE branch used
    // to pin only contentFlagged/posterSuspended/dealNumber, so everything
    // create prevents was reachable one write later: an owner could publish a
    // clean post and then update() their own doc to set posterVerified: true,
    // inflate posterRatingSum/posterRatingCount, flip visibilityMode, or paste
    // a competitor's posterCompanyName/posterLogoUrl onto it.
    //
    // Shape per field: "unchanged OR honest against the caller's own company
    // doc". The unchanged branch is what keeps every ordinary edit working —
    // CapacityModel.toFirestoreForUpdate never sends these keys, and an
    // update() leaves absent keys alone, so on a normal save the RESULTING
    // document (which is what request.resource.data is) still carries exactly
    // the stored values. The honest branch is what
    // CapacityService.updateCompanyNameOnAllPosts and
    // ContactRequestService._syncResponseStatToPosts legitimately do.
    //
    // The numeric signals are checked as BOUNDS, not equality, because the
    // client stores them BANDED (CapacityModel.bandRatingSum/bandRatingCount/
    // bandResponseHours) and a band only ever moves AGAINST the poster —
    // ratings round down, response time rounds up. A bound therefore admits
    // every honest banded value while still making it impossible to claim more
    // than the company doc actually holds, and — unlike re-deriving the exact
    // band here — it can't silently deny every profile save the day a band
    // boundary is tuned in Dart. Under-reporting is self-harm, so it's free.
    //
    // Identity (the first four pins below) is chosen once at create — where
    // it's cross-checked against the caller's own company doc — and never
    // edited by the client afterwards: visibilityMode is deliberately excluded
    // from toFirestoreForUpdate, and the live identity/contact lives on the
    // capacityOwners sidecar, not here. So those are flat pins, no exception.
    function ownerPostSnapshotsHonest() {
      return request.resource.data.get('visibilityMode', 'anonymous') == resource.data.get('visibilityMode', 'anonymous')
        && request.resource.data.get('posterCompanyId', '') == resource.data.get('posterCompanyId', '')
        && request.resource.data.get('posterCompanyName', '') == resource.data.get('posterCompanyName', '')
        && request.resource.data.get('posterLogoUrl', '') == resource.data.get('posterLogoUrl', '')
        // Verified badge: only ever what the caller's own company doc says,
        // and that field is admin/Cloud-Function-only over there.
        && ( request.resource.data.get('posterVerified', false) == resource.data.get('posterVerified', false)
             || ( callerCompanyExists()
                  && request.resource.data.get('posterVerified', false) ==
                       (callerCompany().get('verificationStatus', 'none') == 'verified') ) )
        // Rating pair: never above the (banded-down) real totals.
        && ( ( request.resource.data.get('posterRatingSum', 0) == resource.data.get('posterRatingSum', 0)
               && request.resource.data.get('posterRatingCount', 0) == resource.data.get('posterRatingCount', 0) )
             || ( callerCompanyExists()
                  && request.resource.data.get('posterRatingSum', 0) <= callerCompany().get('ratingSum', 0)
                  && request.resource.data.get('posterRatingCount', 0) <= callerCompany().get('ratingCount', 0) ) )
        // "Antwortet in ~Xh": the claimed hours must be at least the poster's
        // REAL average (hours * 3600000 * samples >= total ms — multiplied out
        // rather than divided so a zero sample count can't divide by zero),
        // behind the same >=3-sample floor the client applies. Dropping the
        // field entirely is a self-downgrade and always allowed.
        && ( request.resource.data.get('posterAvgResponseHours', 0) == resource.data.get('posterAvgResponseHours', 0)
             || !('posterAvgResponseHours' in request.resource.data)
             || ( callerCompanyExists()
                  && callerCompany().get('responseCount', 0) >= 3
                  && request.resource.data.posterAvgResponseHours * 3600000 * callerCompany().get('responseCount', 0)
                       >= callerCompany().get('responseSumMs', 0) ) );
    }

    // Zero-padded 'YYYY-MM-DD' for the server's request time (UTC) — used by the
    // post-throttle counter so a client can't fake the day to reset its quota.
    function todayStr() {
      return string(request.time.year()) + '-' +
        (request.time.month() < 10 ? '0' + string(request.time.month()) : string(request.time.month())) + '-' +
        (request.time.day() < 10 ? '0' + string(request.time.day()) : string(request.time.day()));
    }

    // ─── USERS ───
    // Profile is private to its owner. isAdmin can never be set or changed
    // by the user themselves — it must stay whatever it already was (or
    // absent/false on creation).
    // isAdmin and plan are both privileged: settable only from the Console /
    // by an admin, never self-upgradable. create must not self-grant either;
    // 'plan' may only be absent or 'free' at creation. This is what keeps the
    // dormant paid tier from being self-activated to bypass the contact gate.
    match /users/{uid} {
      // isAdmin() also grants read — an admin managing accounts (promoting
      // another admin, investigating a report) needs to see OTHER users'
      // docs, not just their own.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false) &&
        (!('plan' in request.resource.data) || request.resource.data.plan == 'free');
      // Admin may update ANY user doc without restriction (e.g. promote/
      // demote another admin, adjust plan). Safe from self-escalation:
      // isAdmin() reads the CALLER's own *already-persisted* flag, so a
      // non-admin can never satisfy this branch to grant themselves admin —
      // only an account that is already isAdmin:true can use it. A non-admin
      // still falls through to the self-only branch below, which (unchanged)
      // still blocks them from touching their own isAdmin/plan fields.
      // .get(key, default) guards against docs written before 'plan' existed
      // (kEarlyAccessMode never writes it) — a bare .plan on such a doc
      // errors the whole expression and silently denies the update, which is
      // exactly what was blocking notifyByEmail/notifyOnNewMessage merges.
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == uid &&
            request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) &&
            request.resource.data.get('plan', 'free') == resource.data.get('plan', 'free'));
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ─── COMPANIES ───
    // Public read (browsed by anonymous visitors and shared links). Doc id
    // is always the owner's uid by convention (see CompanyService). Admins
    // moderate verification/flagging. Any signed-in user may additionally
    // touch just ratingSum/ratingCount — needed when CompanyService
    // .submitRating() un-counts someone's own prior approved rating before
    // it goes back to pending for re-review; verifying "they really had an
    // approved rating here" would need an extra read inside the rule, so
    // this is intentionally narrow (those two fields only) rather than that.
    //
    // verificationStatus and contentFlagged are deliberately excluded from
    // the owner's self-update — confirmed by live test that an owner could
    // otherwise write verificationStatus: 'verified' or flip contentFlagged
    // to false directly via the SDK, bypassing admin review entirely. The
    // app's own create/edit flow never sets verificationStatus to anything
    // but 'none'/'pending', and only ever moves contentFlagged false→true
    // (see company_profile_screen.dart) — both are otherwise admin-only.
    //
    // ratingSum/ratingCount are the denormalized review aggregate. They are
    // ADMIN-ONLY: never writable by the owner (they'd inflate their own
    // score) nor by any other signed-in user (they'd forge a competitor's).
    // The aggregate is recomputed admin-side from approved companyRatings
    // docs on every moderation action (see AdminService). The owner's own
    // profile update must therefore leave both fields exactly as they were —
    // a normal profile save (toFirestoreForUpdate) never touches them, so
    // this pin is transparent to the app and only blocks tampering.
    //
    // suspended/suspensionReason are the admin "pause a company" moderation
    // consequence (AdminService.suspendCompany/unsuspendCompany) — same
    // admin-only shape as verificationStatus: a self-write could otherwise
    // un-suspend itself right back out of the consequence. .get(key, default)
    // is used (rather than a bare field reference) since these two fields are
    // absent on every company doc that predates this feature.
    //
    // completedCollaborations/repeatCollaborations and vatValid/vatVerifiedName
    // are server-authored trust BADGES — written only by Cloud Functions via the
    // Admin SDK (onCollabConfirmed, verifyMyCompany) — and are pinned in the
    // owner branch for the same reason as ratingSum: an owner could otherwise
    // SDK-write completedCollaborations: 999 / vatValid: true onto their own doc
    // and forge the credibility company_detail_screen renders, bypassing all of
    // onCollabConfirmed's VAT-gate + velocity-cap + mutual-confirm machinery.
    // lastActiveAt and responseCount/responseSumMs are trust SIGNALS the client
    // itself legitimately writes (login stamp; per-Accept response-time sample),
    // so they can't be flat-pinned — they're instead constrained to their honest
    // write shape (unchanged, or the exact one-step the app performs).
    match /companies/{companyId} {
      allow read: if true;
      // verificationStatus must start at 'none' — 'pending' is reachable ONLY
      // via the verifyMyCompany Cloud Function, after a real VIES check has
      // actually run (Admin SDK write, bypasses rules). Previously a client
      // could self-set 'pending' straight at registration by typing any
      // non-empty string into the VAT field — a real, visible "Verifizierung
      // ausstehend" trust badge for zero verification. Closed here rather
      // than trusted to the client, which no longer even tries (see
      // company_profile_screen.dart).
      // emailVerified — H3 fix: the directory used to list every company the
      // instant it was created, before email verification and before any VAT
      // check, so throwaway Gmail signups could sit in the public directory
      // indefinitely (see CompanyModel.isDirectoryEligible, which
      // CompanyService.getCompanies filters on). Must equal the caller's own
      // token claim at creation — true immediately for Google/Apple (already
      // verified by the provider), false for a fresh email/password account —
      // so a client can't just write emailVerified: true to skip the gate.
      allow create: if isSignedIn() && request.auth.uid == companyId
        && request.resource.data.verificationStatus == 'none'
        && request.resource.data.contentFlagged == false
        && request.resource.data.get('suspended', false) == false
        && request.resource.data.get('emailVerified', false) == request.auth.token.email_verified;
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == companyId
            && request.resource.data.verificationStatus == resource.data.verificationStatus
            && request.resource.data.ratingSum == resource.data.ratingSum
            && request.resource.data.ratingCount == resource.data.ratingCount
            && request.resource.data.get('suspended', false) == resource.data.get('suspended', false)
            && request.resource.data.get('suspensionReason', '') == resource.data.get('suspensionReason', '')
            // Server-authored trust badges — written ONLY by Cloud Functions via
            // the Admin SDK (onCollabConfirmed increments the collaboration
            // counts behind its VAT-verified + 30-day-velocity + mutual-confirm
            // gate; verifyMyCompany sets the VAT pair after a real VIES check),
            // so an owner's own profile save must leave them exactly as they are.
            // Without these pins an owner could SDK-write completedCollaborations:
            // 999 or vatValid: true straight onto their own doc — forging the
            // "X abgeschlossene Zusammenarbeiten" / VAT-verified signals
            // company_detail_screen renders and bypassing all of that machinery.
            // .get(key, default) because each is ABSENT until the first collab/
            // verification (toFirestore never writes them at creation) — a bare
            // field ref would error the rule and deny every profile save on a doc
            // that hasn't earned a badge yet, same as suspended/suspensionReason.
            && request.resource.data.get('completedCollaborations', 0) == resource.data.get('completedCollaborations', 0)
            && request.resource.data.get('repeatCollaborations', 0) == resource.data.get('repeatCollaborations', 0)
            && request.resource.data.get('vatValid', false) == resource.data.get('vatValid', false)
            && request.resource.data.get('vatVerifiedName', '') == resource.data.get('vatVerifiedName', '')
            // vatNumberNormalized (H4 fix) is the equality-lookup key
            // enforceCompanyIntegrity queries for duplicate-VAT detection —
            // same admin-only shape as vatValid/vatVerifiedName above. Left
            // client-writable, an owner could clear it to dodge the dedup
            // query, or set it to someone else's normalized VAT to frame them.
            && request.resource.data.get('vatNumberNormalized', '') == resource.data.get('vatNumberNormalized', '')
            // emailVerified (H3 fix, see the create branch above and
            // CompanyModel.isDirectoryEligible) — a profile save must leave it
            // unchanged UNLESS it's flipping false→true, and even then only
            // when the caller's own token actually proves it now (the
            // "I've verified" refresh in email_verification_banner.dart calls
            // AuthService.reloadAndCheckEmailVerified, which does
            // getIdToken(true) BEFORE writing emailVerified: true, so the
            // fresh claim is already on the token by the time this rule sees
            // the write. Never reachable true→false, and never settable to
            // true by a token that doesn't itself claim verified.
            && ( request.resource.data.get('emailVerified', false) == resource.data.get('emailVerified', false)
                 || ( request.resource.data.get('emailVerified', false) == true
                      && request.auth.token.email_verified == true ) )
            // lastActiveAt and responseCount/responseSumMs are trust signals too
            // ("zuletzt aktiv", "antwortet in ~Xh"), but — unlike the badges above
            // — the client itself legitimately writes them, so they can't be
            // flat-pinned without breaking the app. Constrain them to their honest
            // shape instead:
            //  • lastActiveAt: auth_service.touchLastActive stamps it on login.
            //    Allow unchanged, or exactly request.time (what serverTimestamp()
            //    resolves to here) — blocks future/backdating a liveness the
            //    honest login already grants for free.
            //  • responseCount/responseSumMs: contact_request_service
            //    ._recordResponseTime adds ONE sample per Accept/Decline of an
            //    anonymous-mode request (count +1, sumMs strictly up). Allow only
            //    that one-step (or unchanged) — blocks the one-shot "count: 500,
            //    sumMs: 500" forge of an instant-responder veteran. A script can
            //    still add fake samples one loud write at a time; the airtight fix
            //    is to move this stamp server-side (like functions/index.js
            //    already does for auto-granted posts) and then pin it like above.
            && ( request.resource.data.get('lastActiveAt', null) == resource.data.get('lastActiveAt', null)
                 || request.resource.data.get('lastActiveAt', null) == request.time )
            && ( ( request.resource.data.get('responseCount', 0) == resource.data.get('responseCount', 0)
                   && request.resource.data.get('responseSumMs', 0) == resource.data.get('responseSumMs', 0) )
              || ( request.resource.data.get('responseCount', 0) == resource.data.get('responseCount', 0) + 1
                   && request.resource.data.get('responseSumMs', 0) > resource.data.get('responseSumMs', 0) ) )
            && (request.resource.data.contentFlagged == resource.data.contentFlagged
                || (request.resource.data.contentFlagged == true && resource.data.contentFlagged == false)));
      allow delete: if false;
    }

    // ─── COMPANY CONTACTS (gated contact sidecar) ───
    // email / phone / address / postalCode live HERE, never on the public
    // companies doc above. That doc is `read: if true` so anonymous visitors
    // can browse the directory — which also meant an unauthenticated Firestore
    // REST read returned a clean, structured list of every company's email,
    // phone and street address: a ready-made scraping target aimed at exactly
    // the market this platform is built for. Rules can't hide individual
    // fields, so the contact block had to become its own document.
    //
    // get vs list is deliberate, and is the whole point of splitting them:
    //  • get  — any signed-in, email-verified user may look up ONE company's
    //           contact block (the company detail screen's legitimate use).
    //  • list — admins only. Without this split, a resource-independent
    //           condition like email_verified would authorize a query over the
    //           WHOLE collection, so anyone who signed up and clicked a
    //           verification link could re-scrape the entire directory in a
    //           single request — the same hole, just one signup further away.
    // The owner always reaches their own block (they may not have verified yet,
    // and still need to edit their own profile), and admins reach everything.
    //
    // vatNumber deliberately still lives on the public companies doc: it is
    // load-bearing for the VIES verification + duplicate-VAT machinery
    // (verifyMyCompany, enforceCompanyIntegrity, and the vatNumberNormalized
    // equality query), and moving it is a separate change with real
    // correctness stakes rather than a field relocation.
    match /companyContacts/{companyId} {
      allow get: if isSignedIn() && (
           request.auth.uid == companyId
        || request.auth.token.email_verified == true
        || isAdmin()
      );
      allow list: if isSignedIn() && isAdmin();
      // Only the owner writes their own block (admins additionally, so the
      // one-off backfill that moves existing inline contact off the public doc
      // can run client-side as an admin, same as migrateLegacyIdentityPosts).
      // keys().hasOnly() keeps this document from quietly becoming a second,
      // ungated home for anything else about a company.
      allow create, update: if isSignedIn()
        && (request.auth.uid == companyId || isAdmin())
        && request.resource.data.keys()
             .hasOnly(['email', 'phone', 'address', 'postalCode', 'updatedAt']);
      allow delete: if false;
    }

    // ─── CAPACITIES (anonymized public posts) ───
    // Public read, but the doc carries NO poster identity (no companyId/name/
    // contact) — identity lives only in capacityOwners below. Because the
    // post has no companyId, ownership for edits is resolved through the
    // locked owner sidecar via get(). contentFlagged may only move false→true
    // on a non-admin write. Any signed-in visitor can bump exactly one
    // engagement counter; viewCount also works signed-out.
    //
    // create is just "signed in" + a verified email — the paired
    // capacityOwners doc (written in the same batch) is what binds the post
    // to its real owner; rules can't cross-validate batch siblings (get()
    // sees pre-batch state), and an orphan anonymous post with no owner is
    // contactless and harmless. email_verified is a standard claim on every
    // Firebase Auth ID token (true automatically for Google/Apple sign-in;
    // only email/password accounts start false) — gating on it here, not just
    // in the client, is what actually raises the cost of a throwaway account.
    // A suspended company (admin moderation consequence — see companies/
    // {companyId} above) may not create a post at all, anonymous or not,
    // since visibilityMode:'anonymous' posts carry no identity to filter by
    // later — this is the only point a suspension can actually block a new
    // post from reaching the feed.
    match /capacities/{capacityId} {
      allow read: if true;
      // visibilityMode is chosen once at creation and never revisited (see
      // CapacityModel — the field is excluded from toFirestoreForUpdate).
      // 'anonymous' (or the field being ABSENT, which is how every client
      // release before this one writes a post — deliberately tolerated so
      // this rule deploys safely ahead of the client that starts sending the
      // field, matching CapacityModel.fromFirestore's own missing-field
      // default) must carry NO identity fields at all. 'visible'/'discreet'
      // must carry the CALLER's own identity, cross-checked against their
      // own already-public companies/{uid} doc (cheap — see the identical
      // get() pattern in isGrantedConnectionBetween above) so nobody can
      // post identity claiming to be a different company.
      allow create: if isSignedIn() && request.auth.token.email_verified == true
        // Fails open if the caller has no company doc yet (matches the
        // pre-existing anonymous-post path, which never required one) —
        // exists() guards the get() so a missing doc can't throw and deny
        // the whole rule, same pattern as contact_requests/capacityOwners.
        && ( !exists(/databases/$(database)/documents/companies/$(request.auth.uid))
             || get(/databases/$(database)/documents/companies/$(request.auth.uid)).data.get('suspended', false) == false )
        && (
             ( (!('visibilityMode' in request.resource.data) || request.resource.data.visibilityMode == 'anonymous')
               && !('posterCompanyId' in request.resource.data)
               && !('posterCompanyName' in request.resource.data) )
          || ( ('visibilityMode' in request.resource.data)
               && request.resource.data.visibilityMode in ['visible', 'discreet']
               && request.resource.data.posterCompanyId == request.auth.uid
               && request.resource.data.posterCompanyName ==
                    get(/databases/$(database)/documents/companies/$(request.auth.uid)).data.name
               && ( !('posterLogoUrl' in request.resource.data)
                    || request.resource.data.posterLogoUrl ==
                         get(/databases/$(database)/documents/companies/$(request.auth.uid)).data.logoUrl ) )
           );
      // The owner-update branch pins posterSuspended (like contentFlagged)
      // admin-only — otherwise a suspended company could silently un-hide
      // its own existing posts by editing them, defeating the consequence.
      // dealNumber is likewise pinned — H2 fix: it's now assigned ONLY by the
      // assignDealNumber Cloud Function (Admin SDK, bypasses this rule) the
      // moment status lands on 'closed', drawn from counters/deals, which is
      // itself closed to every client write (see counters/{counterId} below).
      // Without this pin an owner could self-write any dealNumber straight
      // onto their own post, forging the "Deal #N" trust badge.
      // Every OTHER identity/trust field the create rule cross-checks is
      // re-checked on update by ownerPostSnapshotsHonest() (H1 fix) — see that
      // helper at the top of this file for why each field is pinned the way it
      // is. Without it, create's whole cross-check was one update() away from
      // being irrelevant.
      allow update: if isAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/capacityOwners/$(capacityId))
            && get(/databases/$(database)/documents/capacityOwners/$(capacityId)).data.posterCompanyId == request.auth.uid
            && (request.resource.data.contentFlagged == resource.data.contentFlagged
                || (request.resource.data.contentFlagged == true && resource.data.contentFlagged == false))
            && request.resource.data.get('posterSuspended', false) == resource.data.get('posterSuspended', false)
            && request.resource.data.get('dealNumber', null) == resource.data.get('dealNumber', null)
            && ownerPostSnapshotsHonest())
        // Engagement counters double as social proof ("134 Aufrufe", the
        // heart/interest tallies), so a single write may only STEP the counter it
        // touches by its honest client delta — never set it to an arbitrary value.
        // Without the delta pin, .hasOnly(['viewCount']) let an unauthenticated
        // caller pin viewCount to 9999, and any signed-in user do the same to
        // favoriteCount/interestCount on any post. view/interest only ever go
        // +1 (capacity_service.increment*); favoriteCount goes ±1 because
        // toggleFavorite decrements it on un-favourite. .get(..,0) tolerates the
        // field being absent before its first bump (0 + 1 == 1).
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
            && request.resource.data.viewCount == resource.data.get('viewCount', 0) + 1)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoriteCount'])
            && ( request.resource.data.favoriteCount == resource.data.get('favoriteCount', 0) + 1
              || request.resource.data.favoriteCount == resource.data.get('favoriteCount', 0) - 1 ))
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestCount'])
            && request.resource.data.interestCount == resource.data.get('interestCount', 0) + 1);
      allow delete: if false;
    }

    // ─── CAPACITY OWNERS (locked identity sidecar) ───
    // The ONLY place a post's poster identity + contact lives. Released by
    // these rules — never by the client — to the owner, an admin, or a
    // requester holding a *granted* contact request for this exact post.
    // This is the security backbone of the anonymized-post model: an
    // ungranted client physically cannot read it.
    match /capacityOwners/{postId} {
      allow read: if isSignedIn() && (
           resource.data.posterCompanyId == request.auth.uid
        || isAdmin()
        || ( exists(/databases/$(database)/documents/contact_requests/$(request.auth.uid + '_' + postId))
          && get(/databases/$(database)/documents/contact_requests/$(request.auth.uid + '_' + postId)).data.status == 'granted' )
      );
      // Owner creates their own sidecar at post time; admin may also create
      // one (needed to migrate pre-existing posts — including demo companies
      // that have no login — into the split model).
      allow create: if isSignedIn() &&
        (request.resource.data.posterCompanyId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && resource.data.posterCompanyId == request.auth.uid);
      allow delete: if false;
    }

    // ─── CREDITS (Vermittlung wallets) ───
    // One wallet per company at credits/{companyId}. Owner-only read. The quota
    // is pinned to 20 during Early Access (keep in sync with kEarlyAccessQuota).
    // Two legal writes: (a) SPEND — remaining drops by exactly 1 within the same
    // period; (b) monthly RESET — only into the *real* current month, topping
    // remaining back to the quota. The current-month check ties a reset to
    // request.time, so a client can't fake a new period to top up mid-month.
    // Admins may adjust freely (founder approving a screened request debits it).
    match /credits/{companyId} {
      // Owner reads their own wallet; admin may also read it — the founder needs
      // to see the requester's balance when approving a screened request
      // (approveGrant reads the wallet before deciding whether to debit it).
      allow read: if isSignedIn() && (request.auth.uid == companyId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == companyId
        && request.resource.data.quota == 20
        && request.resource.data.remaining == request.resource.data.quota
        && request.resource.data.period ==
             string(request.time.year()) + '-' +
             (request.time.month() < 10 ? '0' + string(request.time.month()) : string(request.time.month()));
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == companyId
            && request.resource.data.quota == resource.data.quota
            && (
                 // Spend one credit, same period.
                 ( request.resource.data.remaining == resource.data.remaining - 1
                   && request.resource.data.remaining >= 0
                   && request.resource.data.period == resource.data.period )
                 // Lazy monthly reset into the actual current month.
              || ( request.resource.data.period != resource.data.period
                   && request.resource.data.remaining == request.resource.data.quota
                   && request.resource.data.period ==
                        string(request.time.year()) + '-' +
                        (request.time.month() < 10 ? '0' + string(request.time.month()) : string(request.time.month())) )
            ));
      allow delete: if false;
    }

    // ─── CONTACT REQUESTS (free, message-first) ───
    // Deterministic id: {requesterCompanyId}_{postId}. Read by the requester,
    // an admin, OR the poster of the referenced post (via the locked sidecar).
    // Create is either 'pending' (anonymous-mode posts — the poster then
    // Accepts/Declines, see the update rule below) or already 'granted' at
    // creation (visible/discreet-mode posts — instant reveal, no accept step;
    // see the second branch of allow create below). The granted branch trusts
    // only the referenced POST's own stored visibilityMode/posterCompanyId,
    // never anything the client claims about itself on the request — so an
    // anonymous post (which never carries a posterCompanyId) can never be
    // tricked into auto-granting.
    match /contact_requests/{reqId} {
      // The deterministic id is {requesterCompanyId}_{postId}. The requester's
      // own flow does a get() on this id to see whether they've already sent a
      // request — and on the FIRST request that doc doesn't exist yet. Without
      // the resource==null branch, `resource.data...` on a missing doc errors
      // and the get() is denied, which is exactly what blocked "Interesse
      // senden". A non-existent read is allowed ONLY for the caller's own id
      // (the reqId must start with their uid), so this can't be used to probe
      // whether some OTHER company has shown interest in a post (that would
      // leak the private interest graph). uids/postIds contain no underscores,
      // so split('_')[0] cleanly yields the requester id.
      // isAdmin() is deliberately LAST in the chain: the two branches above it are
      // the ones real users hit (requester reading their own request, poster
      // reading requests on their own post), and each costs zero or one document
      // access, while isAdmin() always costs one. Ordering the cheap, common
      // branches first keeps the ordinary path off the rules' document-access
      // budget — and keeps a future regression in the isAdmin() helper from being
      // able to block ordinary users again, the way it just did.
      allow read: if isSignedIn() && (
           ( resource == null && reqId.split('_')[0] == request.auth.uid )
        || ( resource != null && (
                resource.data.requesterCompanyId == request.auth.uid
             || ( exists(/databases/$(database)/documents/capacityOwners/$(resource.data.postId))
               && get(/databases/$(database)/documents/capacityOwners/$(resource.data.postId)).data.posterCompanyId == request.auth.uid )
             || isAdmin() ) )
      );
      // FREE, message-first (launch phase): anyone signed in with a verified
      // email may send a first message, always created as 'pending' (no
      // credit, no payment). The poster then accepts/declines it (see update
      // below). email_verified gating here (not just posting) is what closes
      // the "send from fifty throwaway accounts" path email verification is
      // meant to raise the cost of.
      //
      // The last two conditions REJECT a message containing an email address
      // or a 7+ digit run (phone number) outright — unlike capacities/
      // companies (public feed items, where "hide from the feed" is
      // meaningful enforcement), a contact_request's message has no public
      // feed to hide from: the poster's inbox renders it directly, so
      // flagging it after the fact can't undo an already-rendered leak. This
      // is a coarse backstop (no word-boundary regex support relied on here),
      // not a replacement for the client's own live warning
      // (content_moderation.dart) — it exists for the direct-API-write case
      // that warning can't reach.
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.resource.data.requesterCompanyId == request.auth.uid
        && request.resource.data.outcome == null
        && !request.resource.data.message.matches('.*[\\w.+-]+@[\\w-]+\\.[a-zA-Z]{2,}.*')
        && !request.resource.data.message.matches('.*[0-9]{7,}.*')
        && (
             ( request.resource.data.status == 'pending'
               // exists() here is a tightening, not just a lookup: an orphan
               // anonymous post with no capacityOwners sidecar was already
               // documented as "contactless and harmless" by design (see that
               // collection's rule above) — this just makes contact_requests
               // actually honor that instead of silently accepting a request
               // for a postId nothing can ever resolve the poster from.
               && exists(/databases/$(database)/documents/capacityOwners/$(request.resource.data.postId))
               && !isBlockedEitherWay(request.auth.uid,
                    get(/databases/$(database)/documents/capacityOwners/$(request.resource.data.postId)).data.posterCompanyId) )
          || ( request.resource.data.status == 'granted'
               && exists(/databases/$(database)/documents/capacities/$(request.resource.data.postId))
               && get(/databases/$(database)/documents/capacities/$(request.resource.data.postId)).data.visibilityMode in ['visible', 'discreet']
               && request.resource.data.posterCompanyId ==
                    get(/databases/$(database)/documents/capacities/$(request.resource.data.postId)).data.posterCompanyId
               && !isBlockedEitherWay(request.auth.uid, request.resource.data.posterCompanyId) )
           );
      allow update: if isAdmin()
        // Requester: record the follow-up outcome on their own request.
        || (isSignedIn() && resource.data.requesterCompanyId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['outcome']))
        // Poster (owns the post via the locked sidecar): accept a pending
        // message → 'granted' (+ stamp own id, which reveals the sidecar to the
        // requester) or decline it → 'declined'. Only status/posterCompanyId
        // may change, and a grant must stamp the poster's own id.
        || ( isSignedIn()
             && resource.data.status == 'pending'
             && exists(/databases/$(database)/documents/capacityOwners/$(resource.data.postId))
             && get(/databases/$(database)/documents/capacityOwners/$(resource.data.postId)).data.posterCompanyId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'posterCompanyId'])
             && ( ( request.resource.data.status == 'granted'
                    && request.resource.data.posterCompanyId == request.auth.uid )
               || request.resource.data.status == 'declined' ) )
        // Either party of a GRANTED connection may set THEIR OWN "we worked
        // together" flag (only their own key, only false→true). When both are
        // set, the onCollabConfirmed function counts the completed collaboration
        // for both firms — mutual, so neither side can inflate its own count.
        // May optionally include actualCrewSize/actualDurationDays in the SAME
        // write (CapacityOS outcome data — either confirmer may set these,
        // first write wins, no reconciliation attempted between two reports).
        || ( isSignedIn()
             && resource.data.status == 'granted'
             && resource.data.requesterCompanyId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collabRequester', 'actualCrewSize', 'actualDurationDays'])
             && request.resource.data.collabRequester == true )
        || ( isSignedIn()
             && resource.data.status == 'granted'
             && exists(/databases/$(database)/documents/capacityOwners/$(resource.data.postId))
             && get(/databases/$(database)/documents/capacityOwners/$(resource.data.postId)).data.posterCompanyId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collabPoster', 'actualCrewSize', 'actualDurationDays'])
             && request.resource.data.collabPoster == true )
        // Poster marking a granted request "seen" (my_capacities_screen.dart's
        // re-engagement badge) — false→true only, same shape as the
        // collabPoster branch above.
        || ( isSignedIn()
             && resource.data.status == 'granted'
             && exists(/databases/$(database)/documents/capacityOwners/$(resource.data.postId))
             && get(/databases/$(database)/documents/capacityOwners/$(resource.data.postId)).data.posterCompanyId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByPoster'])
             && request.resource.data.seenByPoster == true );
      allow delete: if false;
    }

    // ─── CHATS (post-accept 1:1 messaging) ───
    // A thread exists only for a *granted* contact request (doc id == the
    // request id) and only its two parties may touch it. Identity is already
    // mutual once accepted, so the thread itself needs no anonymization. The
    // create rule resolves the request (rules get() bypasses read rules) to
    // confirm it's granted and that BOTH real parties are the participants.
    match /chats/{chatId} {
      // Existing chat: only its two participants may read it. NON-existent chat:
      // reading it (which ensureChat + the chat stream do on first open) must be
      // allowed for the two real parties, or the thread can never be created —
      // this is what surfaced as "keine Berechtigung" when opening a fresh chat.
      // chatId == the contact_request id == {requesterId}_{postId}: the requester
      // is the first segment; the poster is resolved from the locked sidecar via
      // the postId segment. Restricting to those two means a missing-chat read
      // can't be used to probe whether OTHER companies are connected.
      allow read: if isSignedIn() && (
           ( resource != null && request.auth.uid in resource.data.participants )
        || ( resource == null
             && chatId.split('_').size() == 2
             && ( chatId.split('_')[0] == request.auth.uid
               || ( exists(/databases/$(database)/documents/capacityOwners/$(chatId.split('_')[1]))
                    && get(/databases/$(database)/documents/capacityOwners/$(chatId.split('_')[1])).data.posterCompanyId == request.auth.uid ) ) )
      );
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        // Exactly the two real parties — no more. The checks below confirm the
        // requester and poster are BOTH present, but `in` alone can't stop a
        // third uid riding along; once seeded into participants that third
        // account passes every read/write rule here (all keyed off
        // `uid in participants`). Pin the set to size 2 so membership is exactly
        // {requester, poster}. The update rule already freezes participants, so
        // this only needs enforcing at creation.
        && request.resource.data.participants.size() == 2
        && exists(/databases/$(database)/documents/contact_requests/$(chatId))
        && get(/databases/$(database)/documents/contact_requests/$(chatId)).data.status == 'granted'
        && get(/databases/$(database)/documents/contact_requests/$(chatId)).data.requesterCompanyId in request.resource.data.participants
        // Resolve the poster from the LOCKED sidecar (authoritative) rather than
        // the request's posterCompanyId, which the self-grant flow stamps async.
        && get(/databases/$(database)/documents/capacityOwners/$(get(/databases/$(database)/documents/contact_requests/$(chatId)).data.postId)).data.posterCompanyId in request.resource.data.participants;
      // Participants may bump the last-message preview, never change membership.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        // Resolve participants from the PARENT chat via get() — not the message's
        // own resource.data. A list query (the message stream) has no
        // participants filter, so a resource.data-based rule makes Firestore
        // reject the whole read ("not allowed") even though single-doc creates
        // succeed. The get() is resource-independent, so the list passes.
        //
        // exists() guards the get() above it — same pattern used throughout
        // this file (see contact_requests/capacityOwners/companyRatings).
        // Without it, watching this subcollection before the parent chat doc
        // has actually been created (ensureChat() is async; a client can start
        // watching messages before that write lands, especially on the
        // RECIPIENT's first-ever open of a brand-new chat) makes `.data` on a
        // nonexistent get() throw, denying the WHOLE listener rather than
        // just returning an empty result — which showed up as one side of a
        // first-time contact being unable to open the chat at all while the
        // (separately-delivered) push notification still arrived fine.
        allow read: if isSignedIn()
          && exists(/databases/$(database)/documents/chats/$(chatId))
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // senderId must be self; the message's audience must be the SAME SET as
        // the parent chat's participants (so it can't be planted with a forged
        // audience). Compared with hasAll+hasOnly, not ==, because the two
        // parties build the participants list in opposite order ([me, other]) —
        // an ordered compare denied whichever side didn't create the chat.
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants.hasAll(get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
          && request.resource.data.participants.hasOnly(get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow update, delete: if false;
      }
    }

    // ─── USER FAVORITES ───
    // Each doc belongs to exactly one user — read/create/delete own only,
    // never updated in place (toggling just deletes and re-creates).
    //
    // read also allows resource == null (the doc doesn't exist) — without
    // that, checking "have I favorited this?" for a post you haven't
    // favorited yet (the doc doesn't exist) fails permission-denied, since
    // resource.data can't be compared on a null resource. That silently
    // broke toggleFavorite() for every first-time favorite. Confirmed by
    // live test: a get() on a non-existent userFavorites doc threw
    // permission-denied before this fix. "Doesn't exist" leaks nothing, so
    // this is safe — reads of another user's *existing* favorite doc are
    // still denied by the userId check below.
    // ─── USER BLOCKS ───
    // One-directional block record, deterministic id {blockerCompanyId}_
    // {blockedCompanyId} — mirrors the contact_requests id shape. Only the
    // blocker may create/delete their own block; both companyRatings-style
    // "resource == null" reads are allowed so a client can cheaply check
    // "have I blocked this company?" for an id that doesn't exist yet
    // (isBlockedEitherWay above uses exists(), not a client read, so this
    // read rule is purely for the block/unblock UI's own toggle state).
    match /userBlocks/{blockId} {
      allow read: if isSignedIn() &&
        (resource == null || resource.data.blockerCompanyId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && blockId == request.auth.uid + '_' + request.resource.data.blockedCompanyId
        && request.resource.data.blockerCompanyId == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.blockerCompanyId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /userFavorites/{favId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── COMPANY RATINGS ───
    // Approved reviews are public. A rater can always read/write their own
    // rating doc, but every client-side write must leave it in 'pending' —
    // only an admin can move it to approved/rejected. Unlike companies/
    // capacities, ratings ARE hard-deletable — a rater can withdraw their
    // own review, or an admin can remove one entirely — since a deleted
    // rating's intended count contribution is reversible client-side
    // (CompanyService.deleteRating un-counts it from the company's
    // ratingSum/ratingCount in the same transaction if it was approved),
    // unlike capacities/companies where history has separate trust value.
    match /companyRatings/{ratingId} {
      // resource == null first: getMyRatingForCompany() .get()s a rating doc
      // that usually doesn't exist yet (most viewers haven't rated a given
      // company). Firestore evaluates this rule even for a missing doc, and
      // resource.data on a null resource throws — without this guard that
      // aborts the whole OR chain (denied) instead of falling through to a
      // clean "not found", so every not-yet-rated company view errored for
      // any non-admin viewer.
      allow read: if resource == null
        || (resource.data.status == 'approved')
        || (isSignedIn() && resource.data.raterUserId == request.auth.uid)
        || isAdmin();
      // create/update: beyond the pre-existing self-only + pending-only
      // checks, the rater must name a GRANTED contact_request (viaRequestId)
      // that actually connects them to the company being rated. This is the
      // authoritative check — CompanyService.findGrantedRequestId() on the
      // client only decides what the UI *offers*; a direct API write still
      // has to satisfy isGrantedConnectionBetween() here.
      allow create, update: if isAdmin()
        || (isSignedIn()
            && request.resource.data.raterUserId == request.auth.uid
            && request.resource.data.raterUserId != request.resource.data.companyId
            && request.resource.data.status == 'pending'
            && 'viaRequestId' in request.resource.data
            && isGrantedConnectionBetween(
                 request.resource.data.viaRequestId,
                 request.auth.uid,
                 request.resource.data.companyId));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.raterUserId == request.auth.uid);
    }

    // ─── REPORTS ───
    // Anyone signed in can file a report; only admins can read or manage
    // the queue.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ─── DEAL COUNTER ───
    // Single shared doc handing out sequential deal numbers. H2 fix: this used
    // to allow any signed-in client to write value == resource.value + 1,
    // which is a monotonic step but NOT tied to any real deal closing — a
    // script could loop that write to corrupt/inflate the sequence and
    // contend with every real closure on this one hotspot doc. Now written
    // ONLY by the assignDealNumber Cloud Function (Admin SDK, bypasses these
    // rules) inside its own transaction the moment a capacity's status lands
    // on 'closed' — closed to every client write, create included.
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ─── POST THROTTLE (daily per-company cap) ───
    // One counter per company at postCounts/{uid}: {day:'YYYY-MM-DD', count}.
    // The post-create batch (see CapacityService.createCapacity) writes this in
    // the SAME batch as the new post; if the increment would exceed the daily
    // cap the update is denied, and because batches are atomic the whole post is
    // rejected too. This keeps the throttle enforcement here without touching
    // the capacities/capacityOwners create rules (so admin/onboarding paths are
    // unaffected). Cap = 10/day (keep in sync with kMaxPostsPerDay). The day is
    // pinned to request.time so a client can't backdate to reset its quota.
    match /postCounts/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && request.resource.data.count == 1;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && (
             // Same day: increment by exactly 1, capped.
             ( resource.data.day == todayStr()
               && request.resource.data.count == resource.data.count + 1
               && request.resource.data.count <= 10 )
             // New day: reset to 1.
          || ( resource.data.day != todayStr()
               && request.resource.data.count == 1 )
        );
      allow delete: if false;
    }

    // ─── MESSAGE THROTTLE (daily per-account cap) ───
    // Same shape/pattern as postCounts above, for chat messages. Cap = 200/day
    // (keep in sync with kMaxMessagesPerDay) — generous for real usage, tight
    // enough to blunt a scripted flood. ChatService.sendMessage's existing
    // batch (message + thread preview + unread bump) gains this counter write
    // in the SAME batch, so exceeding the cap fails the whole send atomically.
    match /messageCounts/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && request.resource.data.count == 1;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && (
             ( resource.data.day == todayStr()
               && request.resource.data.count == resource.data.count + 1
               && request.resource.data.count <= 200 )
          || ( resource.data.day != todayStr()
               && request.resource.data.count == 1 )
        );
      allow delete: if false;
    }

    // ─── RATING THROTTLE (daily per-account cap) ───
    // Same pattern, for companyRatings creates. Cap = 20/day (keep in sync
    // with kMaxRatingsPerDay) — a real company rating 20 different partners
    // in one day is already generous; a script trying to rate its way through
    // many sock-puppet-manufactured "collaborations" (Part 17.1 of the audit)
    // hits this fast. CompanyService.submitRating gains a same-batch counter
    // write (see below) — only on CREATE (a first rating for that company),
    // since editing an existing rating doesn't create a new document.
    match /ratingCounts/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && request.resource.data.count == 1;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && (
             ( resource.data.day == todayStr()
               && request.resource.data.count == resource.data.count + 1
               && request.resource.data.count <= 20 )
          || ( resource.data.day != todayStr()
               && request.resource.data.count == 1 )
        );
      allow delete: if false;
    }

    // ─── REPORT THROTTLE (daily per-account cap) ───
    // Same pattern, for reports. Cap = 10/day (keep in sync with
    // kMaxReportsPerDay).
    match /reportCounts/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && request.resource.data.count == 1;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.day == todayStr()
        && (
             ( resource.data.day == todayStr()
               && request.resource.data.count == resource.data.count + 1
               && request.resource.data.count <= 10 )
          || ( resource.data.day != todayStr()
               && request.resource.data.count == 1 )
        );
      allow delete: if false;
    }

    // ─── SAVED SEARCHES (retention) ───
    // A user's persisted feed filters — private to the owner. read allows the
    // resource==null case (a get on a not-yet-created doc) for consistency with
    // the other own-doc collections, though the app only ever queries by ownerId.
    match /savedSearches/{searchId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }

    // ─── NOTIFICATIONS ───
    // One doc per (event, recipient); admin events fan out to one doc per
    // admin, each independently readable/markable only by that admin.
    // Everything except `read` is server-authored via the Admin SDK (Cloud
    // Functions bypass rules entirely) — the client's only legal write is
    // flipping its own doc's `read` to true.
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // ─── CLIENT ERRORS (write-only crash sink) ───
    // Uncaught client errors land here (see ErrorService / M6). Append-only: no
    // client ever reads or mutates them — the founder triages from the console
    // (Admin bypasses rules). Create is intentionally open to signed-out callers
    // too (errors happen on public pages, pre-login), so the real gate is App
    // Check enforcement — the write must come from a genuine app instance. The
    // shape is pinned and the free-text fields length-capped so the collection
    // can't be turned into an arbitrary, unbounded write sink.
    match /clientErrors/{errorId} {
      allow read, update, delete: if false;
      allow create: if request.resource.data.keys().hasOnly(
             ['message', 'stack', 'context', 'uid', 'url',
              'userAgent', 'appVersion', 'createdAt'])
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000
        && request.resource.data.get('stack', '') is string
        && request.resource.data.get('stack', '').size() <= 8000
        && request.resource.data.get('context', '') is string
        && request.resource.data.get('context', '').size() <= 200
        && request.resource.data.get('url', '') is string
        && request.resource.data.get('url', '').size() <= 500
        && request.resource.data.get('userAgent', '') is string
        && request.resource.data.get('userAgent', '').size() <= 500;
    }

    // Everything else (including the unused legacy `favorites` collection)
    // is closed by default.
  }
}
